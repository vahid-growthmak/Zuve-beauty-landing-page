{% render 'page-hero',
  title: article.title,
  crumb: article.title,
  parent_title: blog.title,
  parent_url: blog.url %}

<article class="article">
  <p class="article__meta">
    {{ article.published_at | date: '%B %-d, %Y' }}
    {%- if article.author != blank %} &middot; {{ article.author }}{% endif -%}
  </p>

  {%- if article.image -%}
    <img class="article__hero" src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | escape }}" width="1400" height="900" loading="eager">
  {%- endif -%}

  <div class="rte">{{ article.content }}</div>

  {%- if blog.comments_enabled? -%}
    <section class="article__comments" id="comments">
      <h2 class="display-2">{{ 'blogs.comments.title' | t: count: article.comments_count }}</h2>
      {%- for comment in article.comments -%}
        <article class="pdp-review-card">
          <p class="pdp-review-card__body">{{ comment.content }}</p>
          <div class="pdp-review-card__meta">
            <span class="pdp-review-card__author">{{ comment.author }}</span>
            <span class="pdp-review-card__date">{{ comment.created_at | date: '%B %-d, %Y' }}</span>
          </div>
        </article>
      {%- endfor -%}

      {%- form 'new_comment', article, class: 'contact__form' -%}
        {%- if form.posted_successfully? -%}
          <p role="status">{{ 'blogs.comments.success' | t }}</p>
        {%- elsif form.errors -%}
          <p role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="contact__field">
          <label for="comment-author">{{ 'contact.form.name' | t }}</label>
          <input id="comment-author" type="text" name="comment[author]" value="{{ form.author }}" required>
        </div>
        <div class="contact__field">
          <label for="comment-email">{{ 'contact.form.email' | t }}</label>
          <input id="comment-email" type="email" name="comment[email]" value="{{ form.email }}" required>
        </div>
        <div class="contact__field">
          <label for="comment-body">{{ 'contact.form.message' | t }}</label>
          <textarea id="comment-body" name="comment[body]" rows="5" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="btn btn--filled btn--brown"><span>{{ 'blogs.comments.submit' | t }}</span></button>
      {%- endform -%}
    </section>
  {%- endif -%}
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{ "name": "Article" }
{% endschema %}
