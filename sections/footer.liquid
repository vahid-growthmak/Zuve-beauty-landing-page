<footer class="footer" role="contentinfo">
  <div class="footer__top">
    <a href="{{ routes.root_url }}" class="footer__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 500 | image_tag: class: 'logo-img', alt: shop.name, style: 'width:auto;height:80px;', loading: 'lazy', widths: '250,500' }}
      {%- else -%}
        <img class="logo-img" src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name | escape }}" style="width:auto;height:80px;" width="340" height="80" loading="lazy">
      {%- endif -%}
    </a>
    {%- if section.settings.statement != blank -%}
      <p class="footer__statement"><em>{{ section.settings.statement }}</em></p>
    {%- endif -%}
  </div>

  <div class="footer__cols">
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading | default: block.settings.menu.title }}</h4>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="footer__social" aria-label="{{ 'general.accessibility.social' | t }}">
    {%- assign socials = 'instagram,pinterest,youtube,tiktok' | split: ',' -%}
    {%- for network in socials -%}
      {%- assign key = 'social_' | append: network -%}
      {%- assign url = section.settings[key] -%}
      {%- if url != blank -%}
        <a href="{{ url }}" aria-label="{{ network | capitalize }}" rel="noopener" target="_blank">
          {% render 'icon', name: network %}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="footer__legal">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.legal_note }}</p>
    <ul>
      {%- for link in section.settings.legal_menu.links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "statement", "label": "Brand statement", "default": "Your nails. Your ritual. Your story." },
    { "type": "text", "id": "legal_note", "label": "Legal note", "default": "Crafted in India." },
    { "type": "link_list", "id": "legal_menu", "label": "Legal menu", "default": "footer" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "social_instagram", "label": "Instagram" },
    { "type": "url", "id": "social_pinterest", "label": "Pinterest" },
    { "type": "url", "id": "social_youtube", "label": "YouTube" },
    { "type": "url", "id": "social_tiktok", "label": "TikTok" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
