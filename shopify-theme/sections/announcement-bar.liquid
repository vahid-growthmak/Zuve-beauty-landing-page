{%- if section.blocks.size > 0 -%}
  <div class="announcement" role="region" aria-label="{{ 'general.accessibility.announcement' | t }}">
    <div class="announcement__track">
      {%- comment -%}
        The marquee needs its content twice so the CSS translate loop is seamless.
      {%- endcomment -%}
      {%- for pass in (1..2) -%}
        {%- for block in section.blocks -%}
          <span {{ block.shopify_attributes }}>
            {{- block.settings.text -}}
            {%- if block.settings.show_countdown -%}
              <span class="announcement__timer" data-countdown>48:00:00</span>
            {%- endif -%}
          </span>
          <span class="announcement__dot" aria-hidden="true">&#9670;</span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "First Drop is Live — Reserve Your Set" },
        { "type": "checkbox", "id": "show_countdown", "label": "Append drop countdown", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "message", "settings": { "text": "First Drop is Live — Reserve Your Set" } },
        { "type": "message", "settings": { "text": "Complimentary Delivery on Orders Above ₹999" } },
        { "type": "message", "settings": { "text": "The Evening Collection — Closes in ", "show_countdown": true } }
      ]
    }
  ]
}
{% endschema %}
