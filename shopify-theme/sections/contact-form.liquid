<section class="contact">
  {%- assign details = section.blocks | where: 'type', 'detail' -%}
  {%- if details.size > 0 -%}
    <aside class="contact__info">
      <h2 class="contact__info-title">{{ section.settings.info_title }}</h2>
      {%- for block in details -%}
        <div class="contact__detail" {{ block.shopify_attributes }}>
          <span class="contact__detail-label">{{ block.settings.label }}</span>
          <span class="contact__detail-value">{{ block.settings.value }}</span>
        </div>
      {%- endfor -%}
    </aside>
  {%- endif -%}

  {%- form 'contact', class: 'contact__form' -%}
    {%- if form.posted_successfully? -%}
      <p class="contact__success" role="status">{{ section.settings.success_message }}</p>
    {%- elsif form.errors -%}
      <p class="contact__error" role="alert">{{ form.errors | default_errors }}</p>
    {%- endif -%}

    <div class="contact__field">
      <label for="cf-name">{{ 'contact.form.name' | t }}</label>
      <input id="cf-name" name="contact[name]" type="text" autocomplete="name" value="{{ form.name }}" required>
    </div>
    <div class="contact__field">
      <label for="cf-email">{{ 'contact.form.email' | t }}</label>
      <input id="cf-email" name="contact[email]" type="email" autocomplete="email" value="{{ form.email }}" required>
    </div>
    {%- if section.settings.topics != blank -%}
      <div class="contact__field">
        <label for="cf-topic">{{ section.settings.topic_label }}</label>
        <select id="cf-topic" name="contact[topic]">
          {%- assign topics = section.settings.topics | split: ',' -%}
          {%- for topic in topics -%}
            <option value="{{ topic | strip | escape }}">{{ topic | strip }}</option>
          {%- endfor -%}
        </select>
      </div>
    {%- endif -%}
    <div class="contact__field">
      <label for="cf-order">{{ 'contact.form.order' | t }}</label>
      <input id="cf-order" name="contact[order]" type="text" placeholder="{{ section.settings.order_placeholder }}">
    </div>
    <div class="contact__field">
      <label for="cf-message">{{ 'contact.form.message' | t }}</label>
      <textarea id="cf-message" name="contact[body]" rows="5" required>{{ form.body }}</textarea>
    </div>
    <button type="submit" class="btn btn--filled btn--brown"><span>{{ 'contact.form.send' | t }}</span></button>
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "info_title", "label": "Info title", "default": "Reach the studio." },
    { "type": "text", "id": "topic_label", "label": "Topic label", "default": "What can we help with?" },
    { "type": "textarea", "id": "topics", "label": "Topics (comma separated)", "default": "Order & delivery, Sizing & fit, Returns & refunds, Wholesale & collaboration, Press & media, Other" },
    { "type": "text", "id": "order_placeholder", "label": "Order placeholder", "default": "ZB-000000" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thank you — we’ll be in touch within one working day." }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Contact detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Customer Care" },
        { "type": "html", "id": "value", "label": "Value", "default": "<a href=\"mailto:support@zuvebeauty.com\">support@zuvebeauty.com</a>" }
      ]
    }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
