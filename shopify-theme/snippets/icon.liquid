{%- comment -%}
  Renders an inline SVG icon.
  Usage: {% render 'icon', name: 'search', size: 20 %}
{%- endcomment -%}
{%- assign s = size | default: 20 -%}
{%- case name -%}
  {%- when 'search' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle><line x1="16.5" y1="16.5" x2="21" y2="21"></line>
    </svg>
  {%- when 'account' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <circle cx="12" cy="8" r="4"></circle><path d="M4 21c1.5-4 5-6 8-6s6.5 2 8 6"></path>
    </svg>
  {%- when 'bag' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M5 8h14l-1.2 12.2a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8z"></path>
      <path d="M9 8V6a3 3 0 0 1 6 0v2"></path>
    </svg>
  {%- when 'close' -%}
    <svg viewBox="0 0 24 24" width="{{ s | plus: 4 }}" height="{{ s | plus: 4 }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line>
    </svg>
  {%- when 'arrow-right' -%}
    <svg viewBox="0 0 24 24" width="{{ s | default: 14 }}" height="{{ s | default: 14 }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <line x1="4" y1="12" x2="20" y2="12"></line><polyline points="14 6 20 12 14 18"></polyline>
    </svg>
  {%- when 'check' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M3 12l4 4L21 6"></path>
    </svg>
  {%- when 'monogram' -%}
    <svg viewBox="0 0 200 160" fill="currentColor" aria-hidden="true" style="width:auto;height:{{ s }}px;">
      <polygon points="97,16 103,10 103,150 97,144" />
      <rect x="40" y="40" width="120" height="6" />
      <rect x="40" y="40" width="6" height="40" />
      <polygon points="120,40 160,40 80,140 40,140" />
      <rect x="40" y="134" width="120" height="6" />
    </svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M16 28c0-6 4-10 10-10 0 6-4 10-10 10z"></path>
      <path d="M16 28c0-6-4-10-10-10 0 6 4 10 10 10z"></path>
      <line x1="16" y1="28" x2="16" y2="4"></line>
    </svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M16 4l11 4v8c0 7-5 12-11 14C10 28 5 23 5 16V8l11-4z"></path>
      <path d="M11 16l3.5 3.5L21 13"></path>
    </svg>
  {%- when 'cruelty-free' -%}
    <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M8 13L4 17l4 4"></path><path d="M4 17h16a8 8 0 0 1 8 8"></path>
      <path d="M24 19l4-4-4-4"></path><path d="M28 15H12a8 8 0 0 0-8 8"></path>
    </svg>
  {%- when 'clock' -%}
    <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <circle cx="16" cy="16" r="12"></circle><polyline points="16 8 16 16 22 19"></polyline>
    </svg>
  {%- when 'truck' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <rect x="3" y="6" width="13" height="11" rx="1"></rect><path d="M16 9h3l2 3v5h-5z"></path>
      <circle cx="7" cy="18" r="1.5"></circle><circle cx="18" cy="18" r="1.5"></circle>
    </svg>
  {%- when 'shield-sm' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
    </svg>
  {%- when 'check-circle' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="10"></circle><path d="M8 12l2.5 2.5L16 9"></path>
    </svg>
  {%- when 'clock-sm' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
    </svg>
  {%- when 'instagram' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle>
      <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"></circle>
    </svg>
  {%- when 'pinterest' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M11 7c3 0 5 1.6 5 4.3 0 2.7-1.6 4.5-3.7 4.5-1.1 0-2-.6-2.3-1.3l-.6 2.3c-.2.8-.9 1.8-1.4 2.4"></path>
      <line x1="10.5" y1="14.5" x2="12.5" y2="7.5"></line>
    </svg>
  {%- when 'youtube' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <rect x="2" y="6" width="20" height="12" rx="3"></rect>
      <polygon points="10 9 15 12 10 15" fill="currentColor"></polygon>
    </svg>
  {%- when 'tiktok' -%}
    <svg viewBox="0 0 24 24" width="{{ s }}" height="{{ s }}" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5"></path><path d="M14 4c.5 2.5 2 4 4.5 4"></path>
    </svg>
  {%- when 'file' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 2l4.5 4.5a3 3 0 0 1 0 4.24l-8.5 8.5a3 3 0 0 1-4.24 0l-1.5-1.5a3 3 0 0 1 0-4.24l8.5-8.5a3 3 0 0 1 4.24 0z"></path>
    </svg>
  {%- when 'brush' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 21v-4a4 4 0 1 1 4 4h-4"></path><path d="M21 3a16 16 0 0 0 -12.8 10.2"></path>
      <path d="M21 3a16 16 0 0 1 -10.2 12.8"></path><path d="M10.6 9a9 9 0 0 1 4.4 4.4"></path>
    </svg>
  {%- when 'sparkle' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M16 18a2 2 0 0 1 2 2a2 2 0 0 1 2 -2a2 2 0 0 1 -2 -2a2 2 0 0 1 -2 2zm0 -12a2 2 0 0 1 2 2a2 2 0 0 1 2 -2a2 2 0 0 1 -2 -2a2 2 0 0 1 -2 2zm-7 12a6 6 0 0 1 6 -6a6 6 0 0 1 -6 -6a6 6 0 0 1 -6 6a6 6 0 0 1 6 6z"></path>
    </svg>
{%- endcase -%}
