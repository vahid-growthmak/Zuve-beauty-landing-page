{% render 'page-hero', title: 'Your Rituals', crumb: 'Account' %}
<section class="account">
  <p class="lede">{{ customer.name }} &middot; <a href="{{ routes.account_logout_url }}" class="link-arrow">{{ 'customer.account.log_out' | t }}</a></p>

  <h2 class="display-2">{{ 'customer.orders.title' | t }}</h2>
  {%- if customer.orders.size > 0 -%}
    <table class="account__orders">
      <thead>
        <tr>
          <th>{{ 'customer.orders.order_number' | t }}</th>
          <th>{{ 'customer.orders.date' | t }}</th>
          <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
          <th>{{ 'customer.orders.total' | t }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr>
            <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: '%B %-d, %Y' }}</td>
            <td>{{ order.fulfillment_status_label }}</td>
            <td>{{ order.total_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p>{{ 'customer.orders.none' | t }}</p>
  {%- endif -%}

  <h2 class="display-2">{{ 'customer.addresses.title' | t }}</h2>
  <p>{{ customer.default_address | format_address }}</p>
  <a href="{{ routes.account_addresses_url }}" class="link-arrow">{{ 'customer.addresses.manage' | t }}</a>
</section>
