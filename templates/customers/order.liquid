{% render 'page-hero', title: order.name, crumb: order.name, parent_title: 'Account', parent_url: routes.account_url %}
<section class="account">
  <p class="lede">{{ order.created_at | date: '%B %-d, %Y' }} &middot; {{ order.financial_status_label }}</p>
  <table class="account__orders">
    <thead><tr><th>{{ 'customer.order.product' | t }}</th><th>{{ 'products.product.quantity' | t }}</th><th>{{ 'customer.orders.total' | t }}</th></tr></thead>
    <tbody>
      {%- for line in order.line_items -%}
        <tr><td>{{ line.title }}</td><td>{{ line.quantity }}</td><td>{{ line.final_line_price | money }}</td></tr>
      {%- endfor -%}
    </tbody>
  </table>
  <p><strong>{{ 'customer.orders.total' | t }}: {{ order.total_price | money }}</strong></p>
  <p>{{ order.shipping_address | format_address }}</p>
</section>
