{%- comment -%}
  Slide-in bag. Rebuilt client-side from /cart.js after every add — see theme.js.
{%- endcomment -%}
<div class="cart-drawer" id="cartDrawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{{ 'sections.cart.title' | t }}">
  <div class="cart-drawer__scrim" data-cart-close></div>
  <aside class="cart-drawer__panel">
    <header class="cart-drawer__head">
      <span class="eyebrow">{{ 'sections.cart.title' | t }}</span>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
        {% render 'icon', name: 'close', size: 20 %}
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-drawer-body>
      <p class="cart-drawer__empty">{{ 'sections.cart.empty' | t }}</p>
    </div>

    <footer class="cart-drawer__foot">
      <div class="cart-drawer__row">
        <span>{{ 'sections.cart.subtotal' | t }}</span>
        <strong data-cart-drawer-subtotal>{{ cart.total_price | money }}</strong>
      </div>
      <p class="cart-drawer__note">{{ 'sections.cart.tax_note' | t }}</p>
      <a href="{{ routes.cart_url }}/checkout" class="btn btn--filled btn--brown cart-drawer__checkout">
        <span>{{ 'sections.cart.checkout' | t }}</span>
      </a>
      <a href="{{ routes.cart_url }}" class="link-arrow">{{ 'sections.cart.view_bag' | t }}</a>
    </footer>
  </aside>
</div>
